{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amp.protocol/schemas/agent-card/v1",
  "title": "AgentCard",
  "description": "Agent Card - public document describing an agent on AMP network (MVP)",
  "type": "object",
  "required": ["metadata", "spec"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["id", "name", "version", "owner"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^did:mesh:agent:[a-zA-Z0-9_-]+$",
          "description": "Agent DID"
        },
        "name": { "type": "string", "description": "Agent name" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "created": { "type": "string", "format": "date-time" },
        "updated": { "type": "string", "format": "date-time" },
        "owner": {
          "type": "string",
          "pattern": "^did:mesh:org:[a-zA-Z0-9_-]+$"
        },
        "labels": { "type": "object", "additionalProperties": { "type": "string" } },
        "annotations": { "type": "object", "additionalProperties": true }
      }
    },
    "spec": {
      "type": "object",
      "required": ["domains", "capabilities", "endpoints"],
      "properties": {
        "domains": {
          "type": "object",
          "required": ["primary"],
          "properties": {
            "primary": {
              "type": "array",
              "items": { "type": "string" },
              "minItems": 1
            },
            "secondary": { "type": "array", "items": { "type": "string" } },
            "tags": { "type": "array", "items": { "type": "string" } }
          }
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id"],
            "properties": {
              "id": { "type": "string" },
              "description": { "type": "string" },
              "languages": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "operational": {
          "type": "object",
          "properties": {
            "max_concurrent_tasks": { "type": "integer", "minimum": 1 },
            "avg_latency_ms": { "type": "integer", "minimum": 0 },
            "regions": {
              "type": "object",
              "properties": {
                "deployed": { "type": "array", "items": { "type": "string" } },
                "data_residency": { "type": "array", "items": { "type": "string" } }
              }
            }
          }
        },
        "endpoints": {
          "type": "object",
          "required": ["control_plane", "data_plane"],
          "properties": {
            "control_plane": {
              "type": "object",
              "required": ["nats_subject"],
              "properties": {
                "nats_subject": { "type": "string", "minLength": 1 }
              }
            },
            "data_plane": {
              "type": "object",
              "required": ["grpc"],
              "properties": {
                "grpc": { "type": "string", "format": "uri" },
                "websocket": { "type": "string", "format": "uri" }
              }
            }
          }
        },
        "context_contract": {
          "type": "object",
          "properties": {
            "ref": { "type": "string", "format": "uri" },
            "hash": { "type": "string" }
          }
        }
      }
    },
    "status": {
      "type": "object",
      "properties": {
        "health": { "type": "string", "enum": ["healthy", "degraded", "unhealthy"] },
        "last_heartbeat": { "type": "string", "format": "date-time" },
        "trust_score": { "type": "number", "minimum": 0, "maximum": 5 },
        "total_tasks": { "type": "integer", "minimum": 0 },
        "success_rate": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
