# Copy to .env and fill in. Do not commit .env.
# Required for root docker-compose (docker compose up -d)
POSTGRES_PASSWORD=change-me-secure-password
SESSION_TOKEN_SECRET=change-me-32-char-secret

# ── Data Plane Relay ──────────────────────────────────────────────────────────
# Set to your EC2 public IP or DNS name so providers register the correct
# address in their Agent Card data_plane.grpc field.
# Defaults to "localhost" (local dev only).
RELAY_PUBLIC_HOST=localhost
