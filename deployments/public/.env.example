# Copy to .env and fill in. Do not commit .env.
POSTGRES_PASSWORD=change-me-secure-password
NATS_TOKEN=change-me-nats-token
SESSION_TOKEN_SECRET=change-me-shared-session-secret

# Required in production: protects POST/PATCH/DELETE /agents from unauthorized writes.
# Generate with: openssl rand -base64 32
REGISTRY_WRITE_TOKEN=change-me-registry-write-token

# Set to 1 to enforce all production security checks at startup.
# With AMP_SAFE_MODE=1, the services refuse to start if any required secret is missing.
# Recommended: always set to 1 in production, leave at 0 for local dev.
AMP_SAFE_MODE=0
