{
  "name": "public-mesh-openai-demo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "install:all": "npm install --legacy-peer-deps --prefix provider && npm install --legacy-peer-deps --prefix consumer",
    "run:provider": "npm run start --prefix provider",
    "run:consumer": "npm run start --prefix consumer",
    "keys:consumer": "node scripts/generate-ed25519-keypair.js consumer",
    "keys:provider": "node scripts/generate-ed25519-keypair.js provider",
    "certs:dev": "bash scripts/generate-dev-certs.sh",
    "test": "node --test test/*.test.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0"
  }
}
