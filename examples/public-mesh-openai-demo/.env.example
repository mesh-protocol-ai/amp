# Copy to .env and fill in. Used by provider and consumer.
# NATS_URL = host:port only (do NOT put the token here). Token goes in NATS_TOKEN.

NATS_URL=nats.meshprotocol.dev:4222
NATS_TOKEN=your_token_here
REGISTRY_URL=https://api.meshprotocol.dev
OPENAI_API_KEY=sk-your-openai-key
SESSION_TOKEN_SECRET=replace-with-strong-shared-secret
DATAPLANE_BIND=0.0.0.0:50051
DATAPLANE_PUBLIC_ENDPOINT=grpc://127.0.0.1:50051
PROVIDER_ED25519_PRIVATE_KEY_BASE64=base64_pkcs8_private_key_for_provider
CONSUMER_ED25519_PRIVATE_KEY_BASE64=base64_pkcs8_private_key_for_consumer
ALLOW_LEGACY_DATAPLANE=0
DATAPLANE_ALLOW_INSECURE=0
DATAPLANE_TLS_CA_CERT_PATH=../certs/dev/ca.crt
DATAPLANE_TLS_SERVER_CERT_PATH=../certs/dev/server.crt
DATAPLANE_TLS_SERVER_KEY_PATH=../certs/dev/server.key
DATAPLANE_TLS_REQUIRE_CLIENT_CERT=1
DATAPLANE_TLS_CLIENT_CERT_PATH=../certs/dev/client.crt
DATAPLANE_TLS_CLIENT_KEY_PATH=../certs/dev/client.key
DATAPLANE_TLS_SERVER_NAME=localhost
METRICS_PORT=9095
