# Copy to .env and fill in. Community (OPEN): token simples HMAC, sem E2E.

NATS_URL=nats.meshprotocol.dev:4222
NATS_TOKEN=your_token_here
REGISTRY_URL=https://api.meshprotocol.dev
REGISTRY_WRITE_TOKEN=your_registry_write_token_here
OPENAI_API_KEY=sk-your-openai-key
SESSION_TOKEN_SECRET=replace-with-strong-shared-secret
DATAPLANE_BIND=0.0.0.0:50051
# Static public endpoint (used when NOT behind NAT or when relay is not configured).
DATAPLANE_PUBLIC_ENDPOINT=grpc://127.0.0.1:50051

# Relay tunnel — set RELAY_HOST to your relay server's public IP/hostname to enable
# NAT traversal. When set, RELAY_HOST takes precedence over DATAPLANE_PUBLIC_ENDPOINT.
# The provider opens an outbound TCP connection to the relay so no inbound port is needed.
#
# IMPORTANT: when using the relay, set DATAPLANE_ALLOW_INSECURE=1 on the provider.
# The relay is a transparent TCP proxy — TLS certs issued for the provider's hostname
# are not valid for the relay's hostname, so TLS verification fails on the consumer
# side. The relay itself (your EC2) is trusted infrastructure; auth is via session token.
#
# RELAY_HOST=relay.meshprotocol.dev
# RELAY_CONTROL_PORT=7000
# RELAY_DATA_PORT=7001
DATAPLANE_ALLOW_INSECURE=0
DATAPLANE_TLS_CA_CERT_PATH=../certs/dev/ca.crt
DATAPLANE_TLS_SERVER_CERT_PATH=../certs/dev/server.crt
DATAPLANE_TLS_SERVER_KEY_PATH=../certs/dev/server.key
DATAPLANE_TLS_SERVER_NAME=localhost
METRICS_PORT=9095
